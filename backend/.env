# ============================================
# Configurare Bază de Date MariaDB
# ============================================
DB_HOST=89.37.29.249
DB_PORT=3306
DB_USER=balu1349_gabi
DB_PASSWORD=Eva1Japo2@@@
DB_NAME=balu1349_gabi

# ============================================
# Configurare JWT
# ============================================
# Secretul pentru access token (min 32 caractere)
JWT_ACCESS_SECRET=your_super_secret_access_key_min_32_chars
# Secretul pentru refresh token (diferit de access secret)
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars
# Durata de viață access token (în secunde, default 1 oră)
JWT_ACCESS_EXPIRES_IN=3600
# Durata de viață refresh token (în secunde, default 7 zile)
JWT_REFRESH_EXPIRES_IN=604800

# ============================================
# Configurare Server
# ============================================
PORT=4000
NODE_ENV=development
# URL-ul frontend-ului pentru CORS
FRONTEND_URL=http://localhost:8080
ADMIN_URL=http://localhost:8080

# ============================================
# Configurare Upload Imagini
# ============================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
# Redis pentru rate limiting persistent (opțional, default: memorie)
REDIS_URL=redis://localhost:6379

