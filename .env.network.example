# Copiază acest fișier ca .env.local când vrei să accesezi aplicația de pe telefon
# în rețea la http://IP_PC:8080 (ex: http://192.168.1.146:8080).
# Înlocuiește 192.168.1.146 cu IP-ul real al calculatorului tău (ipconfig / ifconfig).
VITE_GRAPHQL_ENDPOINT=http://192.168.1.146:4000/graphql
VITE_API_BASE_URL=http://192.168.1.146:4000
